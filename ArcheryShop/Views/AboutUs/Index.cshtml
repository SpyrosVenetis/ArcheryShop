@{
    ViewData["Title"] = "About Us";
}

<div class="video-header">
    <video autoplay loop muted playsinline class="banner-video">
        <source src="~/Assets/ArcheryVideoBanner.mp4" type="video/mp4">
    </video>
</div>

<div class="container mt-5">
    <div class="about-header mb-5">
        <h1>About Us</h1>
        <p>Welcome to our Archery Shop! We are passionate about archery and dedicated to providing the best products and services to our customers. Our mission is to promote the sport of archery and help archers of all levels find the perfect equipment to enhance their skills.</p>
    </div>

    <div class="row mb-4">
        <div class="col-lg-6 mb-4">
            <div class="about-card">
                <h2>Our Story</h2>
                <p>Founded in 2026, our shop started as a small local business with a vision to create a community for archery enthusiasts. Over the years, we have grown into a trusted name in the archery industry, offering a wide range of products from top brands</p>
            </div>
        </div>
        <div class="col-lg-6 mb-4">
            <div class="about-card">
                <h2>Our Products</h2>
                <p>We offer a comprehensive selection of archery equipment, including bows, arrows, accessories, and apparel. Whether you're a beginner or an experienced archer, we have something for everyone.</p>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-6 mb-4">
            <div class="about-card">
                <h2>Our Commitment</h2>
                <p>At our Archery Shop, we are committed to customer satisfaction and quality service. We strive to create a welcoming environment where archers can learn, grow, and connect with others who share their passion for the sport. Thank you for choosing us as your go-to destination for all things archery!</p>
            </div>
        </div>
        <div class="col-lg-6 mb-4">
            <div class="about-card">
                <h2>Our Location</h2>
                <p>We are located in Athens, easily accessible by public transportation and ample parking for our customers. Come visit us and explore our wide range of archery products and services.</p>
            </div>
        </div>
    </div>
</div>