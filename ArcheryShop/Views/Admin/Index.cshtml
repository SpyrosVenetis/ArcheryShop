@model IEnumerable<ArcheryShop.Models.Product>

@{
    ViewData["Title"] = "Admin";
}

<div class="row mb-4 justify-content-center">
    <div class="col-auto">
        <form method="get" asp-action="Index" class="d-flex gap-2 justify-content-center">
            <input type="text" name="searchTerm" class="search-input" placeholder="Search" value="@ViewBag.SearchTerm">
        </form>
    </div>
</div>

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Inventory Management</h2>
        <a asp-action="Create" class="btn btn-success fw-bold">+ ADD NEW PRODUCT</a>
    </div>

    <div class="table-responsive shadow-sm bg-white rounded border">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Image</th>
                    <th>Model</th>
                    <th>Brand</th>
                    <th>Price</th>
                    <th>Stock</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td><img src="@item.ImageLink" style="height: 40px; width: 40px; object-fit: contain;"></td>
                        <td class="fw-bold">@item.Model</td>
                        <td>@item.Brand?.Name</td>
                        <td>@item.Price.ToString("C")</td>
                        <td>
                            <span class="badge @(item.Quantity > 0 ? "bg-info" : "bg-danger")">
                                @item.Quantity
                            </span>
                        </td>
                        <td class="text-center">
                            <a asp-action="Edit" asp-route-id="@item.ProductId" class="btn btn-sm btn-outline-primary">Edit</a>
                            <form asp-action="Delete" asp-route-id="@item.ProductId" method="post" onsubmit="return confirm('Are you sure?');" style="display:inline;">
                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                    Delete
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>